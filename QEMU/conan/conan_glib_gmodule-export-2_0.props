<?xml version="1.0" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
	<ImportGroup Label="PropertySheets">
		<Import Condition="'$(Configuration)' == 'Release' And '$(Platform)' == 'x64'" Project="conan_glib_gmodule-export-2_0_release_x64.props"/>
		<Import Condition="'$(Configuration)' == 'Debug' And '$(Platform)' == 'x64'" Project="conan_glib_gmodule-export-2_0_debug_x64.props"/>
	</ImportGroup>
	<PropertyGroup>
		<conan_glib_gmodule-export-2_0_props_imported>True</conan_glib_gmodule-export-2_0_props_imported>
	</PropertyGroup>
</Project>