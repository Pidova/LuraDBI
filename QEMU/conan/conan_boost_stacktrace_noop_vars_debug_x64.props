<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="ConanVariables">
    <Conanboost_stacktrace_noopRootFolder>D:\.conan2\p\b\boost8cfab22c365ea\p</Conanboost_stacktrace_noopRootFolder>
    <Conanboost_stacktrace_noopBinaryDirectories></Conanboost_stacktrace_noopBinaryDirectories>
